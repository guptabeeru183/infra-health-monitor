# Infra Health Monitor - Environment Configuration Template
# 
# Copy this file to .env and customize for your environment.
# NEVER commit .env file with actual values - use this template.
#
# Note: All service ports should be unique and not conflict with system services.

# ============================================================================
# CORE MONITORING STACK PORTS
# ============================================================================

# Grafana - Unified monitoring dashboards
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_ADMIN_USER=admin

# Prometheus - Metrics collection and time-series database
PROMETHEUS_PORT=9090

# Alertmanager - Alert routing and notification
ALERTMANAGER_PORT=9093

# ============================================================================
# NETDATA - Real-time system monitoring
# ============================================================================

NETDATA_PORT=19999
# Netdata streaming (parent-child communication)
NETDATA_STREAMING_PASSWORD=yournetdatapass

# ============================================================================
# SIGNOZ - Logs, Metrics, and Traces
# ============================================================================

# SigNoz Query Service
SIGNOZ_PORT=3301

# ClickHouse (SigNoz backend) - Internal port, not exposed
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000

# OpenTelemetry Collector - OTLP receivers
OTEL_COLLECTOR_OTLP_GRPC_PORT=4317
OTEL_COLLECTOR_OTLP_HTTP_PORT=4318
OTEL_COLLECTOR_METRICS_PORT=8888

# ============================================================================
# UPTIME KUMA - Service uptime monitoring
# ============================================================================

UPTIME_KUMA_PORT=3001

# ============================================================================
# PROMETHEUS CONFIGURATION
# ============================================================================

# Global scrape interval for metrics collection
PROMETHEUS_SCRAPE_INTERVAL=15s

# Metric retention time (format: 15d, 30d, etc.)
PROMETHEUS_RETENTION_TIME=15d

# Maximum storage size for metrics
PROMETHEUS_RETENTION_SIZE=50GB

# ============================================================================
# GRAFANA CONFIGURATION
# ============================================================================

# Grafana datasource settings
GRAFANA_PROMETHEUS_URL=http://prometheus:9090
GRAFANA_SIGNOZ_URL=http://signoz-query-service:3301

# Grafana session settings
GRAFANA_SESSION_COOKIE_SECURE=false

# ============================================================================
# ALERTMANAGER CONFIGURATION
# ============================================================================

# SMTP Configuration for email alerts
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_FROM=alertmanager@monitoring.local
SMTP_USERNAME=alerts@company.com
SMTP_PASSWORD=your_smtp_password

# Alert receiver email
ALERT_EMAIL_TO=alerts@company.com

# Slack Webhook for Slack notifications (optional)
SLACK_WEBHOOK_CRITICAL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty Service Key (optional)
# PAGERDUTY_SERVICE_KEY=your_pagerduty_key

# ============================================================================
# DOCKER COMPOSE CONFIGURATION
# ============================================================================

# Network name for service communication
MONITORING_NETWORK=monitoring-network

# Restart policy for services
COMPOSE_RESTART_POLICY=unless-stopped

# ============================================================================
# RESOURCE LIMITS (Optional - uncomment to enable)
# ============================================================================

# CPU limits (e.g., "1" for 1 CPU, "0.5" for half CPU)
# PROMETHEUS_CPU_LIMIT=2
# GRAFANA_CPU_LIMIT=1
# SIGNOZ_CPU_LIMIT=2

# Memory limits (e.g., "1G", "512M")
# PROMETHEUS_MEMORY_LIMIT=2G
# GRAFANA_MEMORY_LIMIT=1G
# SIGNOZ_MEMORY_LIMIT=4G
# NETDATA_MEMORY_LIMIT=512M

# ============================================================================
# LOGGING
# ============================================================================

# Log level for services (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Docker log driver
DOCKER_LOG_DRIVER=json-file
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3

# ============================================================================
# VOLUME LOCATIONS (if using host volumes instead of named volumes)
# ============================================================================

# Uncomment if using host-based volumes (not recommended for production)
# PROMETHEUS_DATA_VOLUME=/var/lib/prometheus-data
# GRAFANA_DATA_VOLUME=/var/lib/grafana-data
# SIGNOZ_DATA_VOLUME=/var/lib/signoz-data
