{
  "dashboard": {
    "title": "Capacity Planning and Resource Forecasting",
    "description": "Resource usage trends, capacity utilization forecasts, and planning metrics",
    "tags": [
      "capacity",
      "planning",
      "forecasting",
      "resources",
      "trends"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "1h",
    "time": {
      "from": "now-90d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Resource Planning Overview",
        "type": "text",
        "gridPos": {
          "h": 2,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "options": {
          "content": "# Capacity Planning and Resource Forecasting\n90-day trend analysis with growth forecasts for infrastructure capacity planning and budget allocation"
        }
      },
      {
        "id": 2,
        "title": "CPU Utilization Trend (90 Days)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 2
        },
        "targets": [
          {
            "expr": "100 - (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"}[5m]) * 100)",
            "refId": "A",
            "legendFormat": "{{ instance }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              }
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "right"
          }
        }
      },
      {
        "id": 3,
        "title": "Memory Utilization Trend (90 Days)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 2
        },
        "targets": [
          {
            "expr": "100 * (1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"})) ",
            "refId": "A",
            "legendFormat": "{{ instance }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              }
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "right"
          }
        }
      },
      {
        "id": 4,
        "title": "Disk Usage Trend (90 Days)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 10
        },
        "targets": [
          {
            "expr": "100 * (1 - (node_filesystem_avail_bytes{instance=~\"$instance\", mountpoint=\"/\"} / node_filesystem_size_bytes{instance=~\"$instance\", mountpoint=\"/\"}))",
            "refId": "A",
            "legendFormat": "{{ instance }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              }
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          }
        }
      },
      {
        "id": 5,
        "title": "Peak Usage Periods (Last 30 Days)",
        "type": "heatmap",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 18
        },
        "targets": [
          {
            "expr": "100 - (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"}[1h]) * 100)",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "Resource Growth Rate (Weekly)",
        "type": "bargauge",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 18
        },
        "targets": [
          {
            "expr": "rate((100 - (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]) * 100))[7d:1d])",
            "refId": "A",
            "legendFormat": "CPU Growth"
          },
          {
            "expr": "rate((100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)))[7d:1d])",
            "refId": "B",
            "legendFormat": "Memory Growth"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "id": 7,
        "title": "Network Throughput Trend (90 Days)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 26
        },
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total{instance=~\"$instance\", device!=\"lo\"}[5m]) * 8 / 1000000",
            "refId": "A",
            "legendFormat": "RX {{ instance }} (Mbps)"
          },
          {
            "expr": "rate(node_network_transmit_bytes_total{instance=~\"$instance\", device!=\"lo\"}[5m]) * 8 / 1000000",
            "refId": "B",
            "legendFormat": "TX {{ instance }} (Mbps)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Mbps",
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              }
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 8,
        "title": "Resource Allocation Status",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 34
        },
        "targets": [
          {
            "expr": "count(node_memory_MemTotal_bytes{instance=~\"$instance\"})",
            "refId": "A",
            "legendFormat": "Hosts"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 9,
        "title": "Recommended Actions Based on 90-Day Trends",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 34
        },
        "targets": [
          {
            "expr": "topk(10, increase(node_filesystem_size_bytes{mountpoint=\"/\"}[90d]))",
            "refId": "A"
          }
        ]
      }
    ],
    "templating": {
      "list": [
        {
          "name": "instance",
          "type": "query",
          "datasource": "Prometheus",
          "definition": "label_values(node_cpu_seconds_total, instance)",
          "description": "Select host(s) for capacity analysis",
          "multi": true,
          "refresh": "on_time_interval"
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "capacity_events",
          "datasource": "Prometheus",
          "expr": "increase(node_filesystem_size_bytes[5m]) > 0",
          "textFormat": "Resource changes detected"
        }
      ]
    }
  },
  "overwrite": true
}
