{
  "dashboard": {
    "title": "Alerting and Incident Management",
    "description": "Alert history, frequency, resolution time, and incident timeline",
    "tags": [
      "alerting",
      "incidents",
      "alerts",
      "sla",
      "resolution"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-30d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Alerting Dashboard - Incident Tracking",
        "type": "text",
        "gridPos": {
          "h": 2,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "options": {
          "content": "# Alerting and Incident Management\nTrack alert firing frequency, resolution times, and incident distribution across services for SLA/SLO analysis"
        }
      },
      {
        "id": 2,
        "title": "Total Alerts (30 Days)",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 2
        },
        "targets": [
          {
            "expr": "count(increase(ALERTS[30d])) by() > 0",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "title": "Critical Alerts",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 2
        },
        "targets": [
          {
            "expr": "count(ALERTS{severity=\"critical\"}) by() > 0",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "red",
                  "value": 5
                }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Warning Alerts",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 2
        },
        "targets": [
          {
            "expr": "count(ALERTS{severity=\"warning\"})",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 5,
        "title": "Average Alert Resolution Time",
        "type": "gauge",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 2
        },
        "targets": [
          {
            "expr": "avg(histogram_quantile(0.95, rate(prometheus_http_request_duration_seconds_bucket[5m]))) * 1000",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 3600000
                },
                {
                  "color": "red",
                  "value": 86400000
                }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Alert Timeline (30 Days)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 6
        },
        "targets": [
          {
            "expr": "rate(ALERTS[5m])",
            "refId": "A",
            "legendFormat": "Alert Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              }
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "list"
          }
        }
      },
      {
        "id": 7,
        "title": "Alerts by Severity",
        "type": "piechart",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 6
        },
        "targets": [
          {
            "expr": "count by (severity)(ALERTS)",
            "refId": "A",
            "legendFormat": "{{ severity }}"
          }
        ]
      },
      {
        "id": 8,
        "title": "Alert Firing Frequency by Service",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 14
        },
        "targets": [
          {
            "expr": "sum(increase(ALERTS{alertstate=\"firing\"}[1h])) by (job) > 0",
            "refId": "A",
            "legendFormat": "{{ job }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              }
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          }
        }
      },
      {
        "id": 9,
        "title": "Top Firing Alerts (Last 7 Days)",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 22
        },
        "targets": [
          {
            "expr": "topk(10, sum(increase(ALERTS[7d])) by (alertname))",
            "refId": "A"
          }
        ]
      },
      {
        "id": 10,
        "title": "Current Firing Alerts",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 22
        },
        "targets": [
          {
            "expr": "ALERTS{alertstate=\"firing\"}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 11,
        "title": "Alert Distribution by Service and Severity",
        "type": "heatmap",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 30
        },
        "targets": [
          {
            "expr": "count by (job, severity)(ALERTS)",
            "refId": "A"
          }
        ]
      },
      {
        "id": 12,
        "title": "Mean Time to Resolution (MTTR) by Service",
        "type": "bargauge",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 38
        },
        "targets": [
          {
            "expr": "topk(10, sum(rate(alertmanager_alerts_received_total[7d])) by (instance))",
            "refId": "A",
            "legendFormat": "{{ instance }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "service",
          "type": "query",
          "datasource": "Prometheus",
          "definition": "label_values(ALERTS, job)",
          "description": "Select service for detailed alert analysis",
          "multi": false,
          "refresh": "on_time_interval"
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "alert_events",
          "datasource": "Prometheus",
          "expr": "ALERTS{alertstate=\"firing\"}",
          "textFormat": "{{ alertname }} - {{ severity }}"
        }
      ]
    }
  },
  "overwrite": true
}
